# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
backend/dietetyk.db
backend/dietetyk.db-journal

# Dependency directories
node_modules/
jspm_packages/

# Optional npm cache directory
.npm

# Output directories
frontend/dist/
backend/public/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
passwords.txt

# OS files
.DS_Store
Thumbs.db

# Runtime database & SSL certs directory
data/

# Pliki tymczasowe / backupy z refaktoryzacji (nie wdrażać)
backend/server.js.monolith.bak
backend/**/*.tmp

# Tymczasowe, ręcznie rozpakowane przykładowe eksporty (np. Health Auto Export)
# wgrywane lokalnie do analizy formatu danych - nigdy nie commitować (dane zdrowotne).
HealthAutoExport_*/

# Track package-lock.json regardless of global gitignore settings
!package-lock.json
