PORT=3000
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
APP_PASSWORD=dietetyk-admin
OURA_CLIENT_ID=your_oura_client_id_here
OURA_CLIENT_SECRET=your_oura_client_secret_here

# Adres publiczny apki (np. https://dietetyk.example.com) - używany do budowania
# redirect_uri w przepływach OAuth (Oura/Withings/Google) oraz jako dozwolone
# źródło CORS. Bez tego część integracji może nie działać poprawnie na produkcji.
APP_URL=

# Sekret do podpisywania (HMAC) parametru `state` w przepływie OAuth (ochrona
# przed CSRF). Opcjonalne - jeśli nie ustawione, backend użyje APP_PASSWORD jako
# zapasowego sekretu (patrz services/oauthHelpers.js). Zalecane na produkcji jako
# osobny, dedykowany sekret (nie to samo hasło, co panel admina).
OAUTH_STATE_SECRET=

# Withings OAuth - opcjonalne, używane głównie przez skrypty testowe
# (test-withings.js); w normalnym działaniu klucze są skonfigurowane per-użytkownik
# w panelu Ustawień, nie globalnie.
WITHINGS_CLIENT_ID=your_withings_client_id_here
WITHINGS_CLIENT_SECRET=your_withings_client_secret_here
WITHINGS_REDIRECT_URI=

# Hasło początkowego konta admina tworzonego przy pierwszym starcie backendu.
# Jeśli nie ustawione, backend wygeneruje losowe hasło i wypisze je raz w logach.
ADMIN_INITIAL_PASSWORD=

# Katalog, w którym backend trzyma plik bazy SQLite. Jeśli nie ustawione, używany
# jest katalog backendu (__dirname) - przydatne do wskazania trwałego wolumenu
# w Dockerze.
DATABASE_DIR=
